{
  "dashboard": {
    "title": "Beta Swarm Overview",
    "tags": ["beta-swarm"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Active Agents",
        "type": "stat",
        "targets": [
          {
            "expr": "swarm_agents_total",
            "legendFormat": "Agents"
          }
        ],
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "Task Success Rate",
        "type": "gauge",
        "targets": [
          {
            "expr": "swarm_tasks_completed / (swarm_tasks_completed + swarm_tasks_failed)",
            "legendFormat": "Success Rate"
          }
        ],
        "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0}
      },
      {
        "id": 3,
        "title": "RAM Usage %",
        "type": "graph",
        "targets": [
          {
            "expr": "swarm_ram_usage_percent",
            "legendFormat": "RAM %"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4}
      },
      {
        "id": 4,
        "title": "CPU Usage %",
        "type": "graph",
        "targets": [
          {
            "expr": "swarm_cpu_usage_percent",
            "legendFormat": "CPU %"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4}
      }
    ],
    "time": {"from": "now-1h", "to": "now"},
    "refresh": "30s"
  }
}
