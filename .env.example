# Swarm Configuration
LMSTUDIO_BASE_URL=http://localhost:1234/v1
OLLAMA_BASE_URL=http://localhost:11434/v1
AIDER_MODEL=gemini/gemini-pro
CHECKPOINT_DIR=./checkpoints
WORKSPACE_DIR=./workspace
OBSIDIAN_VAULT_PATH=./obsidian-vault

# AI Provider Keys
GOOGLE_API_KEY=your_google_api_key_here
GROQ_API_KEY=your_groq_api_key_here
CEREBRAS_API_KEY=your_cerebras_api_key_here
SAMBANOVA_API_KEY=your_sambanova_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
MISTRAL_API_KEY=your_mistral_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
CLOUDFLARE_API_KEY=your_cloudflare_api_key_here
HUGGINGFACE_API_KEY=your_huggingface_api_key_here
GITHUB_TOKEN=your_github_token_here

# Infrastructure
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here
KUZU_DB_PATH=./kuzu_db
LETTA_API_URL=http://localhost:8283
COGNEE_API_URL=http://localhost:8000
HERMES_PATH=C:\path\to\hermes-agent

# Error Monitoring
BUGSINK_DSN=http://localhost:8001/api/error/

# Gumloop & Webhook Tunneling
GUMLOOP_EMAIL=user@gmail.com
GUMLOOP_PASSWORD=your_gumloop_password_here
NGROK_AUTHTOKEN=your_ngrok_authtoken_here

# Cognee & LLM Config
LLM_ENDPOINT=http://host.docker.internal:11434
LLM_API_KEY=dummy
EMBEDDING_ENDPOINT=http://host.docker.internal:11434
EMBEDDING_API_KEY=dummy
EMBEDDING_DIMENSIONS=768
HUGGINGFACE_TOKENIZER=nomic-ai/nomic-embed-text-v1.5
GOOGLE_AI_STUDIO_API_KEY=your_google_ai_studio_api_key_here
